   function toggleLoader(s) { document.getElementById('loader').style.display = s ? 'flex' : 'none'; }

   function initLuxSelect(id, icon) {
  if (instances[id]) instances[id].destroy();
  instances[id] = new TomSelect(`#${id}`, {
    create: false, sortField: null, placeholder: "-- Pilih --", allowEmptyOption: true,
    render: {
      option: (d, e) => `<div><i class="${icon} select-icon"></i>${e(d.text)}</div>`,
      item: (d, e) => `<div><i class="${icon} select-icon"></i>${e(d.text)}</div>`
    }
  });

  instances[id].on('change', () => {
    // JIKA BUKAN DARI SISTEM (Edit), JALANKAN FILTER OTOMATIS
    if (!isProgrammaticUpdate) {
      if (id === 'jenis') updateSubJenis();
      if (id === 'inp-kegiatan') filterSubKegiatan();
      if (id === 'inp-subkegiatan') filterKoderingBelanja();
      if (id === 'filterBulan') filterData();
      if (id === 'set-tipe') toggleParentSetting();
    }
  });
}

   function updateSubJenis(val = "") {
  const j = document.getElementById('jenis').value;
  const tsSub = instances['subJenis'];
  const ang = document.getElementById('section-anggaran');

  if (tsSub) {
    // 1. Bersihkan pilihan yang sedang terpilih (Tanpa memicu pemicu/event)
    tsSub.clear(true); 

    // 2. Hapus total semua daftar pilihan (options) yang ada di memori Tom Select
    tsSub.clearOptions(); 

    // 3. Masukkan opsi default/kosong kembali
    tsSub.addOption({value: "", text: "-- Pilih --"});

    // 4. Masukkan data baru berdasarkan Jenis yang dipilih
    if (OPTIONS[j]) {
      OPTIONS[j].forEach(o => {
        tsSub.addOption({value: o, text: o});
      });
    }

    // 5. Segarkan tampilan visual Tom Select
    tsSub.refreshOptions(false);

    // 6. Jika sedang mode edit (ada parameter val), set nilainya
    if (val) {
      setTimeout(() => {
        tsSub.setValue(val);
      }, 100);
    }
  }

  // Tampilkan/Sembunyikan seksi anggaran
  if (ang) ang.style.display = (j === "Pengeluaran") ? "block" : "none";
}


  function handleSimpan() {
  const eid = document.getElementById('edit-id').value;
  const isEditMode = (eid !== "" && eid !== null); 
  const btn = document.getElementById('btn-save');
  
  const data = {
    id: eid,
    tanggal: document.getElementById('tanggal').value,
    nomorTBP: document.getElementById('nomorTBP').value,
    jenis: document.getElementById('jenis').value,
    subJenis: document.getElementById('subJenis').value,
    kegiatan: document.getElementById('inp-kegiatan').value,
    subKegiatan: document.getElementById('inp-subkegiatan').value,
    koderingBelanja: document.getElementById('inp-koderingbelanja').value,
    uraian: document.getElementById('uraian').value,
    jumlah: cleanRupiah(document.getElementById('jumlah').value)
  };

  if (!data.tanggal || !data.jumlah || !data.jenis) {
    return Swal.fire('Opps', 'Lengkapi kolom Tanggal, Jenis, dan Jumlah!', 'warning');
  }

  toggleLoader(true);
  btn.disabled = true;

  const targetFunction = isEditMode ? 'updateData' : 'simpanData';

  google.script.run
    .withFailureHandler(err => { 
      // Matikan loading jika server error
      toggleLoader(false); 
      btn.disabled = false; 
      Swal.fire('Gagal!', err.message, 'error'); 
    })
    .withSuccessHandler(res => {
      // PENTING: Bungkus dengan try-catch agar jika UI error, loading tetap bisa mati
      try {
        ALL_DATA = res; 
        FILTERED_DATA = [...res]; 

        // 1. Matikan loading segera setelah data diterima
        toggleLoader(false);
        btn.disabled = false;

        // 2. Munculkan notifikasi (Gunakan desain mewah)
        Swal.fire({
          title: isEditMode ? 'Berhasil Diperbarui!' : 'Berhasil Disimpan!',
          text: 'Data transaksi telah tercatat di sistem.',
          icon: 'success',
          timer: 2000,
          showConfirmButton: false,
          timerProgressBar: true
        });

        // 3. Jalankan reset (Pastikan fungsi ini tidak ada error)
        handleBatalEdit(); 
        updateStats();
        renderBKU();

      } catch (errUI) {
        console.error("Kesalahan Render UI:", errUI);
        toggleLoader(false); // Pastikan loading mati meskipun render gagal
      }
    })[targetFunction](data);
}

  function muatData() {
    toggleLoader(true);
    google.script.run.withSuccessHandler(res => {
      ALL_DATA = res; FILTERED_DATA = [...res];
      updateStats(); renderBKU(); toggleLoader(false);
    }).ambilSemuaData();
  }

  function updateStats() {
    let t = 0, k = 0;
    ALL_DATA.forEach(r => { t += r.terima; k += r.keluar; });
    document.getElementById('stat-terima').innerText = 'Rp ' + t.toLocaleString('id-ID');
    document.getElementById('stat-keluar').innerText = 'Rp ' + k.toLocaleString('id-ID');
    document.getElementById('stat-saldo').innerText = 'Rp ' + (t - k).toLocaleString('id-ID');
  }

  function filterData() {
  const keyword = document.getElementById('searchInput').value.toLowerCase();
  const bulanDipilih = document.getElementById('filterBulan').value; // Mengambil angka 1-12 atau ""
  const clearBtn = document.getElementById('clearBtn');

  // Toggle tombol X pada search
  keyword ? clearBtn.classList.remove('d-none') : clearBtn.classList.add('d-none');

  if (!ALL_DATA || ALL_DATA.length === 0) return;

  FILTERED_DATA = ALL_DATA.filter(row => {
    // 1. Logika Filter Bulan
    // row.tanggal formatnya YYYY-MM-DD, kita ambil bulannya saja
    const bulanTransaksi = new Date(row.tanggal).getMonth() + 1; 
    const matchBulan = (bulanDipilih === "" || bulanTransaksi.toString() === bulanDipilih);

    // 2. Logika Filter Keyword (Search)
    const stringData = (
      (row.noBku || "") + " " + 
      (row.uraian || "") + " " + 
      (row.nomorTbp || "") + " " + 
      (row.kodeBelanja || "") + " " +
      (row.jenis || "")
    ).toLowerCase();
    const matchKeyword = stringData.includes(keyword);

    // Data tampil jika memenuhi kedua kriteria
    return matchBulan && matchKeyword;
  });

  currentPage = 1; // Reset ke halaman 1 setiap kali filter berubah
  renderBKU();
}

// Fungsi untuk tombol X (Clear)
function clearSearch() {
  const input = document.getElementById('searchInput');
  input.value = '';
  filterData(); // Jalankan filter lagi untuk mereset tampilan
  input.focus();
}

function changeRowsPerPage(v) { rowsPerPage = parseInt(v); currentPage = 1; renderBKU(); }

  function renderBKU() {
  const tbody = document.getElementById('tabelBKU');
  tbody.innerHTML = '';
  
  const start = (currentPage - 1) * rowsPerPage;
  const end = start + rowsPerPage;
  const paginatedData = FILTERED_DATA.slice(start, end);

  // HITUNG SALDO BERJALAN DARI DATA ASLI
  let runningSaldo = 0;
  ALL_DATA.forEach((r) => {
    runningSaldo += (r.terima - r.keluar);
    r.currentSaldo = runningSaldo;
  });

  if (paginatedData.length === 0) {
    tbody.innerHTML = '<tr><td colspan="10" class="text-center py-4 text-secondary">Data tidak ditemukan</td></tr>';
    return;
  }

  paginatedData.forEach((row, idx) => {
    const nomorUrut = start + idx + 1;

    tbody.innerHTML += `
      <tr>
        <td class="text-center col-no">${nomorUrut}</td>
        <td class="fw-bold text-primary no-wrap">${row.noBku}</td>
        <td class="no-wrap">${row.tanggalTampil}</td>
        <td class="text-start">
          <span class="badge bg-light text-dark border fw-normal text-wrap" style="max-width:150px; color:#1e293b !important">
            ${row.nomorTbp || '-'}
          </span>
        </td>
        <td class="col-uraian">
          <div class="fw-bold text-wrap text-justify" style="margin-bottom: 4px;">${row.uraian}</div>
          <div class="text-muted small text-start">${row.jenis} | ${row.subJenis}</div>
        </td>
        <td class="text-center no-wrap">
          <span style="font-size: 13px; font-weight: 500; color: #1e293b;">
            ${row.kodeBelanja || '-'}
          </span>
        </td>
        <td class="text-end text-success no-wrap">
          ${row.terima ? 'Rp ' + row.terima.toLocaleString('id-ID') : '-'}
        </td>
        <td class="text-end text-danger no-wrap">
          ${row.keluar ? 'Rp ' + row.keluar.toLocaleString('id-ID') : '-'}
        </td>
        <td class="text-end fw-bold no-wrap">
          Rp ${row.currentSaldo.toLocaleString('id-ID')}
        </td>
        <td class="text-center">
          <div class="action-wrapper">
            <button class="btn-lux btn-edit-lux" onclick="editRow(${row.id})"><i class="fa-solid fa-pen-to-square"></i></button>
            <button class="btn-lux btn-delete-lux" onclick="confirmDelete(${row.id})"><i class="fa-regular fa-trash-can"></i></button>
          </div>
        </td>
      </tr>
    `;
  });

  renderPagination();
  
  const totalData = FILTERED_DATA.length;
  document.getElementById('pageInfo').innerText = 
    `Menampilkan ${totalData === 0 ? 0 : start + 1} - ${Math.min(end, totalData)} dari ${totalData} data`;
}

  function renderPagination() {
  const pageCount = Math.ceil(FILTERED_DATA.length / rowsPerPage);
  const pag = document.getElementById('pagination');
  pag.innerHTML = '';

  if (pageCount <= 1) {
    document.getElementById('pageInfo').classList.add('d-none');
    return;
  }
  document.getElementById('pageInfo').classList.remove('d-none');

  let paginationHtml = `
    <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
      <button class="page-link" onclick="goToPage(${currentPage - 1})">Prev</button>
    </li>
  `;

  // Logika pembatasan tombol halaman (agar tidak terlalu panjang jika ada 50 halaman)
  let startPage = Math.max(1, currentPage - 2);
  let endPage = Math.min(pageCount, startPage + 4);
  
  if (endPage - startPage < 4) {
    startPage = Math.max(1, endPage - 4);
  }

  for (let i = startPage; i <= endPage; i++) {
    paginationHtml += `
      <li class="page-item ${i === currentPage ? 'active' : ''}">
        <button class="page-link" onclick="goToPage(${i})">${i}</button>
      </li>
    `;
  }

  paginationHtml += `
    <li class="page-item ${currentPage === pageCount ? 'disabled' : ''}">
      <button class="page-link" onclick="goToPage(${currentPage + 1})">Next</button>
    </li>
  `;

  pag.innerHTML = paginationHtml;
}

  function goToPage(p) { currentPage = p; renderBKU(); }

  function confirmDelete(id) {
  Swal.fire({
    title: 'Hapus Data Transaksi?',
    text: "Data ini akan dihapus secara permanen",
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: '#dc2626',
    cancelButtonColor: '#64748b',
    confirmButtonText: 'Ya, Hapus!',
    cancelButtonText: 'Batal',
    reverseButtons: true
  }).then((result) => {
    if (result.isConfirmed) {
      toggleLoader(true);
      
      google.script.run
        .withFailureHandler(err => {
          toggleLoader(false);
          Swal.fire('Gagal!', err.message, 'error');
        })
        .withSuccessHandler(res => {
          // 1. Update data utama dengan data terbaru dari server
          ALL_DATA = res;

          // 2. RESET FILTER BULAN (Kembali ke "Semua Bulan")
          if (instances['filterBulan']) {
            instances['filterBulan'].setValue(""); 
          }

          // 3. RESET PENCARIAN (Opsional, agar sinkron)
          const searchInp = document.getElementById('searchInput');
          if (searchInp) {
            searchInp.value = "";
            document.getElementById('clearBtn').classList.add('d-none');
          }

          // 4. KEMBALIKAN FILTERED_DATA KE DATA PENUH & RESET HALAMAN
          FILTERED_DATA = [...res]; 
          currentPage = 1;

          // 5. REFRESH TAMPILAN
          updateStats();
          renderBKU();
          
          toggleLoader(false);
          
          Swal.fire({
            title: 'Terhapus!',
            text: 'Data telah dihapus dan Nomor BKU telah diurutkan ulang.',
            icon: 'success',
            timer: 1500,
            showConfirmButton: false
          });
        })
        .hapusData(id);
    }
  });
}

  function editRow(id) {
  const row = ALL_DATA.find(r => r.id == id);
  if (!row) return;

  // 1. PINDAH TAB DULU
  const inputTabBtn = document.getElementById('input-tab');
  if (inputTabBtn) new bootstrap.Tab(inputTabBtn).show();

  // 2. KUNCI SISTEM
  isProgrammaticUpdate = true; 
  setNavigationDisabled(true);

  // 3. ISI DATA DASAR (Teks & Tanggal)
  document.getElementById('edit-id').value = row.id;
  document.getElementById('nomorTBP').value = row.nomorTbp || "";
  document.getElementById('uraian').value = row.uraian || "";
  if (fp) fp.setDate(row.tanggal);
  
  const jInp = document.getElementById('jumlah');
  jInp.value = row.nominal.toString();
  formatInputRupiah(jInp);

  // 4. PROSES DROPDOWN (Jeda 400ms agar Tab Render Selesai)
  setTimeout(() => {
    // A. Set Jenis
    if (instances['jenis']) instances['jenis'].setValue(row.jenis);
    
    // B. Set Sub Jenis (Kita suntik manual pilihannya)
    const tsSubJenis = instances['subJenis'];
    if (tsSubJenis) {
      tsSubJenis.clearOptions();
      if (OPTIONS[row.jenis]) {
        OPTIONS[row.jenis].forEach(o => tsSubJenis.addOption({value: o, text: o}));
      }
      tsSubJenis.setValue(row.subJenis);
    }

    // C. LOGIKA ANGGARAN (Sangat Krusial)
    const sectionAnggaran = document.getElementById('section-anggaran');
    if (row.jenis === "Pengeluaran") {
      sectionAnggaran.style.display = "block";
      
      // Ambil data referensi dari memori (ALL_SETTINGS)
      // row.kegiatan, row.subKegiatan, row.kodeBelanja diambil dari mapping ambilSemuaData()
      const kegCode = row.kegiatan;
      const subCode = row.subKegiatan;
      const belanjaCode = row.kodeBelanja;

      // --- SUNTIK KEGIATAN ---
      const tsKeg = instances['inp-kegiatan'];
      if (tsKeg) {
        tsKeg.setValue(kegCode);
      }

      // --- SUNTIK SUB KEGIATAN (Manual Feed) ---
      const tsSubAng = instances['inp-subkegiatan'];
      if (tsSubAng) {
        tsSubAng.clearOptions();
        ALL_SETTINGS.filter(s => s[0] === "Sub Kegiatan" && s[3] === kegCode).forEach(s => {
          tsSubAng.addOption({value: s[1], text: s[1] + " - " + s[2]});
        });
        tsSubAng.setValue(subCode);
      }

