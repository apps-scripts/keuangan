  }
  if (document.getElementById('btn-cancel-setting')) document.getElementById('btn-cancel-setting').classList.add('d-none');

  // 4. RESET TAB LAPORAN
  if (fpReport) fpReport.setDate(new Date()); // Kembalikan tanggal cetak ke hari ini

  // 5. BERSIHKAN SEMUA TOM SELECT (Visual & Opsi)
  Object.keys(instances).forEach(id => {
