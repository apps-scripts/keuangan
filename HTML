function deleteSetting(rowIdx) {
  // 1. Ambil data dari array ALL_SETTINGS berdasarkan index baris
  const data = ALL_SETTINGS[rowIdx - 1];
  const tipe = data[0]; // Kegiatan / Sub Kegiatan / Kodering Belanja
  const nama = data[2]; // Nama uraiannya

  // 2. Tentukan variabel kalimat berdasarkan tipe
  let judul, teks, iconWarna;

  if (tipe === "Kegiatan") {
    judul = "Hapus Kegiatan Utama?";
    teks = `Anda akan menghapus Kegiatan: <b>${nama}</b>. Tindakan ini bersifat permanen!`;
    iconWarna = "#d33"; // Merah pekat
  } 
  else if (tipe === "Sub Kegiatan") {
    judul = "Hapus Sub Kegiatan?";
    teks = `Apakah anda yakin ingin menghapus Sub Kegiatan <b>${nama}</b>?`;
    iconWarna = "#f39c12"; // Oranye
  } 
  else {
    judul = "Hapus Kodering Belanja?";
    teks = `Data <b>${nama}</b> akan dihapus secara permanen dari daftar referensi.`;
    iconWarna = "#e74c3c"; // Merah standar
  }

  // 3. Tampilkan SweetAlert dengan kalimat yang sudah dibedakan
  Swal.fire({
    title: judul,
    html: teks, // Menggunakan 'html' agar bisa pakai tag <b>
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: iconWarna,
    cancelButtonColor: '#6c757d',
    confirmButtonText: 'Ya, Hapus!',
    cancelButtonText: 'Batal',
    reverseButtons: true // Memposisikan tombol 'Batal' di kiri agar lebih ergonomis
  }).then((result) => {
    if (result.isConfirmed) {
      toggleLoader(true);
      google.script.run
        .withFailureHandler(err => {
          toggleLoader(false);
          Swal.fire('Gagal!', err.message, 'error');
        })
        .withSuccessHandler(res => {
          ALL_SETTINGS = res;
          renderSettingsTable();
          populateInputDropdowns();
          toggleLoader(false);
          Swal.fire({
            title: 'Terhapus!',
            text: `${tipe} telah berhasil dihapus.`,
            icon: 'success',
            timer: 1500,
            showConfirmButton: false
          });
        })
        .hapusSetting(rowIdx);
    }
  });
}

function handleSaveSetting() {
  // 1. Ambil ID untuk menentukan apakah ini Update atau Simpan Baru
  const editId = document.getElementById('set-id').value;

  // 2. Kumpulkan data dari form
  const d = { 
    id: editId,
    kategori: document.getElementById('set-tipe').value, 
