  // Fungsi untuk memformat angka saat diketik
function formatInputRupiah(i) {
    let v = i.value.replace(/[^,\d]/g, ""), s = v.split(","), si = s[0].length % 3, r = s[0].substr(0, si), ri = s[0].substr(si).match(/\d{3}/gi);
    if (ri) r += (si ? "." : "") + ri.join(".");
    i.value = s[1] != undefined ? r + "," + s[1] : r;
  }

// Fungsi pembantu untuk mengubah kembali string Rupiah ke angka murni
function cleanRupiah(v) { return parseFloat(v.replace(/\./g, "")) || 0; }

