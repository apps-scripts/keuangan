// TAMBAHKAN INI DI DALAM <SCRIPT> (Bisa di bagian paling bawah)
function setNavigationDisabled(disabled) {
  const bkuTab = document.getElementById('bku-tab');
  const setTab = document.getElementById('set-tab');

  if (!bkuTab || !setTab) {
    console.error("ID bku-tab atau set-tab tidak ditemukan di HTML!");
    return;
  }

  if (disabled) {
    // 1. Tambahkan class visual & blokir klik via CSS
    bkuTab.classList.add('disabled-tab');
    setTab.classList.add('disabled-tab');
    
    // 2. Jika menggunakan tag <button>, gunakan atribut disabled
    bkuTab.disabled = true;
    setTab.disabled = true;

    // 3. Cabut pemicu tab Bootstrap (agar tidak bisa pindah tab lewat keyboard/js)
    bkuTab.setAttribute('data-bs-toggle', 'disabled');
    setTab.setAttribute('data-bs-toggle', 'disabled');
  } else {
    // 1. Kembalikan visual
    bkuTab.classList.remove('disabled-tab');
    setTab.classList.remove('disabled-tab');
    
    // 2. Aktifkan kembali button
    bkuTab.disabled = false;
    setTab.disabled = false;

    // 3. Pasang kembali pemicu tab Bootstrap
    bkuTab.setAttribute('data-bs-toggle', 'tab');
    setTab.setAttribute('data-bs-toggle', 'tab');
  }
}

function initLuxSelect(id, icon) {
  if (instances[id]) instances[id].destroy();
  
  instances[id] = new TomSelect(`#${id}`, {
    create: false,
    // SANGAT PENTING: Set ke null agar tidak diurutkan otomatis oleh library
    sortField: null, 
    placeholder: "-- Pilih --",
    allowEmptyOption: true,
    render: {
      option: function(data, escape) {
        if (data.text.indexOf('-- Pilih --') !== -1 || data.text === "Semua Bulan") {
          return `<div class="py-1 text-secondary">${escape(data.text)}</div>`;
        }
        return `<div class="d-flex align-items-center">
                  <i class="${icon} select-icon me-2"></i>
                  <span>${escape(data.text)}</span>
                </div>`;
      },
      item: function(data, escape) {
        if (data.text.indexOf('-- Pilih --') !== -1 || data.text === "Semua Bulan") {
          return `<div class="text-secondary">${escape(data.text)}</div>`;
        }
        return `<div><i class="${icon} select-icon me-2"></i>${escape(data.text)}</div>`;
      }
    }
  });

  // Listener tetap sama
  instances[id].on('change', () => {
    if (!isProgrammaticUpdate) {
      if (id === 'jenis') updateSubJenis();
      if (id === 'inp-kegiatan') filterSubKegiatan();
      if (id === 'inp-subkegiatan') filterKoderingBelanja();
      if (id === 'filterBulan') filterData();
      if (id === 'set-tipe') toggleParentSetting();
    }
  });
}

function resetApplicationState() {
  // 1. PENGAMAN EDIT
  // Jika sedang proses edit, jangan jalankan reset agar data di form tidak hilang
