      text: 'Nomor Kodering dan Nama/Uraian wajib diisi!',
      confirmButtonColor: '#2563eb'
    });
  }

  toggleLoader(true);

  // 4. Kirim ke Server
  google.script.run
    .withFailureHandler(err => {
      toggleLoader(false);
      Swal.fire('Gagal Simpan', err.message, 'error');
    })
    .withSuccessHandler(res => {
      // Update variabel data lokal
      ALL_SETTINGS = res;
      
      // Refresh tampilan tabel dan dropdown di Tab Input
      renderSettingsTable();
      populateInputDropdowns();
      
      // 5. RESET FORM & KEMBALIKAN TOMBOL KE MODE TAMBAH
