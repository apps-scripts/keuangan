    if (clearBtn) clearBtn.classList.add('d-none');
  }

  // B. Reset Dropdown Filter Bulan (Tom Select) ke "Semua Bulan"
  if (instances['filterBulan']) {
    instances['filterBulan'].setValue("", true); // "" = Semua Bulan, true = silent (tidak trigger event)
  }

  // C. Reset Baris Per Halaman ke Default (5 Baris)
  const rowsSelect = document.getElementById('rowsPerPageSelect');
  if (rowsSelect) {
    rowsSelect.value = "5";
    rowsPerPage = 5; // Pastikan variabel global rowsPerPage juga diupdate
  }

  // D. Kembalikan Data ke Kondisi Penuh & Halaman 1
  FILTERED_DATA = [...ALL_DATA]; 
  currentPage = 1;

  // E. Render Ulang Tabel agar bersih
  renderBKU();

  // 8. SELESAI
  setTimeout(() => { 
    isProgrammaticUpdate = false; 
  }, 300);
}

function downloadPDF() {
  const bulan = document.getElementById('reportBulan').value;
  const tglCetak = document.getElementById('reportTanggalCetak').value; // Ambil tanggal manual
  
  if(!tglCetak) return Swal.fire('Perhatian', 'Harap pilih tanggal cetak laporan!', 'warning');

  Swal.fire({
    title: 'Menyiapkan PDF...',
    allowOutsideClick: false,
    didOpen: () => { Swal.showLoading(); }
  });

  google.script.run
    .withFailureHandler(err => { Swal.close(); alert(err.message); })
    .withSuccessHandler(dataUri => {
      Swal.close();
      const link = document.createElement('a');
      link.href = dataUri;
      link.download = `Laporan_BKU.pdf`;
      link.click();
    })
    .generatePDF(bulan, tglCetak); // Kirim 2 parameter
}


function populateReportMonths() {
  const ts = instances['reportBulan'];
  if (!ts) return;

  // Bersihkan sisa-sisa data lama
  ts.clearOptions();

  // Tambahkan opsi "Semua Bulan" di paling atas
  ts.addOption({value: "", text: "Semua Bulan"});
  
  const namaBulan = [
    "Januari", "Februari", "Maret", "April", "Mei", "Juni", 
    "Juli", "Agustus", "September", "Oktober", "November", "Desember"
  ];

  // Tambahkan bulan 1-12
  namaBulan.forEach((nama, i) => {
    ts.addOption({
      value: (i + 1).toString(), 
      text: nama
    });
  });

  // Set agar tampilannya mengikuti urutan input (bukan abjad)
  ts.settings.sortField = null;
  ts.refreshOptions(false);
  ts.setValue("", true); // Set default ke "Semua Bulan" secara diam-diam
}

</script>
