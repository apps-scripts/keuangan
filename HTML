  function renderSettingsTable() {
  const tbody = document.getElementById('set-list');
  tbody.innerHTML = '';
  
  if (!ALL_SETTINGS || ALL_SETTINGS.length === 0) {
    tbody.innerHTML = '<tr><td colspan="5" class="text-center py-3">Belum ada referensi</td></tr>';
    return;
  }

  // Filter data belanja saja untuk dasar penghitungan kumulasi pagu ke atas
  let dataBelanja = ALL_SETTINGS.filter(s => s[0] === "Kodering Belanja");
  
  ALL_SETTINGS.forEach((s, index) => {
    let displayPagu = 0;
    let rowIdx = index + 1;
    let hasChildren = false;

    // 1. LOGIKA HITUNG PAGU & CEK DATA TURUNAN (CHILDREN)
    if (s[0] === "Kodering Belanja") {
      displayPagu = parseFloat(s[4]) || 0;
      hasChildren = false;
    } else if (s[0] === "Sub Kegiatan") {
      // Cek apakah ada belanja di bawah sub kegiatan ini
      hasChildren = ALL_SETTINGS.some(item => item[0] === "Kodering Belanja" && item[3] === s[1]);
      // Kumulasi pagu dari belanja yang menginduk ke sub ini
      displayPagu = dataBelanja.filter(b => b[3] === s[1]).reduce((sum, curr) => sum + (parseFloat(curr[4]) || 0), 0);
    } else if (s[0] === "Kegiatan") {
      // Cek apakah ada sub kegiatan di bawah kegiatan ini
      hasChildren = ALL_SETTINGS.some(item => item[0] === "Sub Kegiatan" && item[3] === s[1]);
      // Kumulasi pagu dari semua belanja yang ada di bawah sub kegiatan milik kegiatan ini
      let subKegiatans = ALL_SETTINGS.filter(sub => sub[0] === "Sub Kegiatan" && sub[3] === s[1]);
      subKegiatans.forEach(sub => {
        displayPagu += dataBelanja.filter(b => b[3] === sub[1]).reduce((sum, curr) => sum + (parseFloat(curr[4]) || 0), 0);
      });
    }

    // 2. LOGIKA STYLING (BADGE, BOLD, & WARNA)
    const isMain = (s[0] === "Kegiatan" || s[0] === "Sub Kegiatan");
    
    // Warna Badge
    let badgeClass = (s[0] === "Kegiatan") ? "bg-dark text-white" : 
                     (s[0] === "Sub Kegiatan") ? "bg-secondary text-white" : 
                     "bg-light text-dark border";

    // Ketebalan Teks Kode & Nama
    const weightClass = isMain ? "fw-bold" : "fw-normal";
    const opacityClass = isMain ? "" : "text-secondary";

    // KETEBALAN TEKS NILAI PAGU (Update: Bold hanya untuk Kegiatan & Sub)
    const paguWeightClass = isMain ? "fw-bold" : "fw-normal";

    // 3. LOGIKA PROTEKSI TOMBOL (DISABLE JIKA PUNYA TURUNAN)
    const disabledAttr = hasChildren ? 'disabled' : '';
    const disabledClass = hasChildren ? 'btn-disabled-lux' : '';

    // 4. RENDER KE HTML
    tbody.innerHTML += `
      <tr class="align-top">
        <td>
          <span class="badge ${badgeClass}" style="font-size: 10px; padding: 5px 10px; min-width: 90px;">
            ${s[0]}
          </span>
        </td>
        <td class="no-wrap ${weightClass}" style="color: #db2777; font-size: 11px;">
          ${s[1]}
        </td>
        <td class="${weightClass} ${opacityClass}">
          ${s[2]}
        </td>
        <td class="text-end ${paguWeightClass} text-primary no-wrap">
          Rp ${displayPagu.toLocaleString('id-ID')}
        </td>
        <td class="text-center">
          <div class="action-wrapper">
            <button class="btn-lux btn-edit-lux ${disabledClass}" onclick="editSetting(${rowIdx})" ${disabledAttr} title="${hasChildren ? 'Memiliki turunan data' : 'Edit'}">
              <i class="fa-solid fa-pen"></i>
            </button>
            <button class="btn-lux btn-delete-lux ${disabledClass}" onclick="deleteSetting(${rowIdx})" ${disabledAttr} title="${hasChildren ? 'Memiliki turunan data' : 'Hapus'}">
              <i class="fa-solid fa-trash"></i>
            </button>
          </div>
        </td>
      </tr>
    `;
  });
}

