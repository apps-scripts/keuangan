// FUNGSI GENERATE NOMOR BKU
function generateNoBKU(tanggalStr, koderingSub, jenis) {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sheet = ss.getSheetByName("Data") || ss.insertSheet("Data");
    var tgl = new Date(tanggalStr);
    var bulan = tgl.getMonth() + 1;
    var tahun = tgl.getFullYear();
    
    // 1. Hitung Nomor Urut (Reset setiap bulan)
    var urut = 1;
    var lastRow = sheet.getLastRow();
    if (lastRow > 1) {
      var data = sheet.getRange(2, 1, lastRow - 1, 2).getValues(); // Ambil No BKU dan Tanggal
      var count = data.filter(function(row) {
        if (!row[1]) return false;
        var d = new Date(row[1]);
        return d.getMonth() + 1 === bulan && d.getFullYear() === tahun;
      }).length;
      urut = count + 1;
    }
    var noUrutStr = ("000" + urut).slice(-3); // Format 001, 002, dst.

    // 2. Bulan Romawi
    var romawi = ["I","II","III","IV","V","VI","VII","VIII","IX","X","XI","XII"][bulan-1];

    // 3. LOGIKA FORMAT NOMOR (PERMINTAAN BARU)
    // Jika Jenis adalah Pelimpahan, Pengembalian, atau Pajak
    if (jenis === "Pelimpahan" || jenis === "Pengembalian" || jenis === "Pajak") {
      return noUrutStr + "/" + romawi; 
    } 
    // Jika selain itu (Pengeluaran), gunakan format lengkap dengan kodering
    else {
      var sliceKodering = "00.00";
      if (koderingSub && koderingSub.toString().indexOf('.') !== -1) {
        var parts = koderingSub.split('.');
        // Mengambil bagian ke-5 (indeks 4) dan 2 digit terakhir dari bagian ke-6 (indeks 5)
        var p5 = parts[4] || "00";
        var p6 = parts[5] ? parts[5].slice(-2) : "00";
        sliceKodering = p5 + "." + p6;
      }
      return noUrutStr + "/" + sliceKodering + "/" + romawi;
    }
  } catch (e) {
    return "ERR/" + romawi;
  }
}

function ambilSemuaData() {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sheet = ss.getSheetByName("Data");
    if (!sheet || sheet.getLastRow() < 2) return [];
    
    // Ambil 12 kolom (A sampai L)
    var data = sheet.getRange(2, 1, sheet.getLastRow() - 1, 12).getValues(); 
    
    return data.map((row, index) => ({
      id: index + 2,
      noBku: row[0] ? row[0].toString() : "",
      // SANGAT PENTING: Konversi Tanggal ke String di sini
      tanggal: row[1] instanceof Date ? Utilities.formatDate(row[1], Session.getScriptTimeZone(), "yyyy-MM-dd") : row[1],
      tanggalTampil: row[1] instanceof Date ? Utilities.formatDate(row[1], Session.getScriptTimeZone(), "dd MMM yyyy") : row[1],
      nomorTbp: row[2] || "-",
      kegiatan: row[3] || "-",
      subKegiatan: row[4] || "-",
      kodeBelanja: row[5] || "-",
      uraian: row[6] || "-",
      terima: parseFloat(row[7]) || 0,
      keluar: parseFloat(row[8]) || 0,
      jenis: row[9] || "",
      subJenis: row[10] || "",
      nominal: parseFloat(row[11]) || 0
    }));
  } catch (e) {
    return []; // Jika error, kirim array kosong agar browser tidak stuck
  }
}

function simpanData(obj) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName("Data") || ss.insertSheet("Data");
  var noBKU = generateNoBKU(obj.tanggal, obj.subKegiatan, obj.jenis);

  if (sheet.getLastRow() === 0) {
    sheet.appendRow(["NO BKU", "TANGGAL", "NOMOR TBP", "KEGIATAN", "SUB KEGIATAN", "KODE BELANJA", "URAIAN", "PENERIMAAN", "PENGELUARAN", "JENIS", "SUB JENIS", "NOMINAL"]);
  }

  var terima = (obj.jenis === "Pelimpahan" || (obj.jenis === "Pajak" && obj.subJenis.includes("Potongan"))) ? obj.jumlah : 0;
  var keluar = (obj.jenis === "Pengeluaran" || obj.jenis === "Pengembalian" || (obj.jenis === "Pajak" && obj.subJenis.includes("Penyetoran"))) ? obj.jumlah : 0;

  sheet.appendRow([
    noBKU, obj.tanggal, obj.nomorTBP, obj.kegiatan, obj.subKegiatan, obj.koderingBelanja, 
    obj.uraian, terima, keluar, obj.jenis, obj.subJenis, obj.jumlah
  ]);
  return ambilSemuaData();
}

function hapusData(id) {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sheet = ss.getSheetByName("Data");
    
    // 1. Ambil data baris yang akan dihapus untuk tahu Bulan & Tahunnya
    var rowData = sheet.getRange(id, 1, 1, 2).getValues()[0];
    var tglHapus = new Date(rowData[1]);
    var bulan = tglHapus.getMonth() + 1;
    var tahun = tglHapus.getFullYear();

    // 2. Hapus baris tersebut
    sheet.deleteRow(id);

    // 3. Jalankan fungsi Re-index untuk mengurutkan ulang nomor
    reindexBKU(bulan, tahun);

    return ambilSemuaData();
  } catch (e) {
    throw new Error("Gagal menghapus: " + e.toString());
  }
}

// FUNGSI UNTUK MENGURUTKAN ULANG NOMOR BKU
function reindexBKU(targetBulan, targetTahun) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName("Data");
  var lastRow = sheet.getLastRow();
  
  if (lastRow < 2) return;

  // Ambil semua data (Kolom A: NO BKU, B: Tanggal, H: Jenis, I: Sub Jenis)
  // Kita butuh Jenis dan Sub Jenis untuk menentukan format nomor (Ringkas atau Lengkap)
  var range = sheet.getRange(2, 1, lastRow - 1, 9); 
  var data = range.getValues();
  
  var counter = 1;

  for (var i = 0; i < data.length; i++) {
    var tgl = new Date(data[i][1]);
    var bln = tgl.getMonth() + 1;
    var thn = tgl.getFullYear();

    // Jika bulan dan tahun cocok dengan data yang baru dihapus
    if (bln === targetBulan && thn === targetTahun) {
      var noUrutStr = ("000" + counter).slice(-3);
      var romawi = ["I","II","III","IV","V","VI","VII","VIII","IX","X","XI","XII"][bln-1];
      
      var jenis = data[i][7];
      var oldBku = data[i][0];
      var newBku = "";

      // Logika Penentuan Format Kembali
      if (jenis === "Pelimpahan" || jenis === "Pengembalian" || jenis === "Pajak") {
        newBku = noUrutStr + "/" + romawi;
      } else {
        // Jika Pengeluaran, ambil bagian tengahnya (kodering) dari BKU lama
        var parts = oldBku.split("/");
        var koderingPart = (parts.length === 3) ? parts[1] : "00.00";
        newBku = noUrutStr + "/" + koderingPart + "/" + romawi;
      }

      // Update langsung ke cell di Spreadsheet
      sheet.getRange(i + 2, 1).setValue(newBku);
      counter++;
    }
  }
}

function updateData(obj) {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sheet = ss.getSheetByName("Data");
    var rowId = parseInt(obj.id);

    // Hitung Penerimaan & Pengeluaran
    var terima = (obj.jenis === "Pelimpahan" || (obj.jenis === "Pajak" && obj.subJenis.includes("Potongan"))) ? obj.jumlah : 0;
    var keluar = (obj.jenis === "Pengeluaran" || obj.jenis === "Pengembalian" || (obj.jenis === "Pajak" && obj.subJenis.includes("Penyetoran"))) ? obj.jumlah : 0;
    
    var rowData = [
      obj.tanggal, obj.nomorTBP || "-", obj.kegiatan || "-", obj.subKegiatan || "-", 
      obj.koderingBelanja || "-", obj.uraian, terima, keluar, obj.jenis, obj.subJenis, obj.jumlah
    ];

    // Pastikan range-nya pas (11 kolom mulai dari kolom B)
    sheet.getRange(rowId, 2, 1, 11).setValues([rowData]);
    SpreadsheetApp.flush(); 

    // WAJIB: Kembalikan data terbaru
    return ambilSemuaData(); 
  } catch (f) {
    throw new Error(f.toString()); // Ini akan ditangkap oleh FailureHandler di browser
  }
}

function getSettings() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName("Settings") || ss.insertSheet("Settings");
  if (sheet.getLastRow() < 1) return [];
  return sheet.getRange(1, 1, sheet.getLastRow(), 5).getValues(); // Ambil 5 kolom
}

function addSetting(obj) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName("Settings");
  // Jika ID ada, berarti update. Jika tidak, append baru.
  if (obj.id) {
    sheet.getRange(obj.id, 1, 1, 5).setValues([[obj.kategori, obj.kodering, obj.nama, obj.parent, obj.pagu]]);
  } else {
    sheet.appendRow([obj.kategori, obj.kodering, obj.nama, obj.parent, obj.pagu]);
  }
  return getSettings();
}

// Hapus Baris Setting
function hapusSetting(rowIdx) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName("Settings");
  sheet.deleteRow(rowIdx);
  return getSettings();
}

// Fungsi untuk membuat PDF Buku Kas Umum
function generatePDF(bulan, tanggalCetakManual) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const data = ambilSemuaData(); // Mengambil data Object dari fungsi yang sudah ada
  
  // 1. Logika Filter Data berdasarkan Bulan
  const filteredData = bulan ? data.filter(r => {
    const m = new Date(r.tanggal).getMonth() + 1;
    return m.toString() === bulan;
  }) : data;

  const namaBulanHeader = bulan ? ["Januari", "Februari", "Maret", "April", "Mei", "Juni", "Juli", "Agustus", "September", "Oktober", "November", "Desember"][parseInt(bulan)-1] : "SEMUA BULAN";

  // 2. Format Tanggal Cetak Manual (dari YYYY-MM-DD ke format Indonesia)
  const dCetak = new Date(tanggalCetakManual);
  const bulanIndo = ["Januari", "Februari", "Maret", "April", "Mei", "Juni", "Juli", "Agustus", "September", "Oktober", "November", "Desember"];
  const tglCetakTampil = dCetak.getDate() + " " + bulanIndo[dCetak.getMonth()] + " " + dCetak.getFullYear();

  // 3. BUAT TEMPLATE HTML UNTUK PDF
  let html = `
    <html>
    <head>
      <style>
        body { font-family: sans-serif; font-size: 9px; color: #1e293b; padding: 10px; }
        .header { text-align: center; margin-bottom: 25px; }
        .header h2 { margin: 0; font-size: 16px; text-transform: uppercase; }
        .header p { margin: 5px 0; font-size: 11px; color: #64748b; }
        
        table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
        th { background-color: #f8fafc; border: 0.5pt solid #000; padding: 8px 4px; text-align: center; font-weight: bold; text-transform: uppercase; }
        td { border: 0.5pt solid #000; padding: 6px 4px; vertical-align: top; }
        
        .text-center { text-align: center; }
        .text-end { text-align: right; white-space: nowrap; }
        .fw-bold { font-weight: bold; }
        
        .footer-container { margin-top: 40px; width: 100%; }
        .ttd-box { float: right; width: 220px; text-align: center; font-size: 10px; }
        .space-ttd { height: 60px; }
      </style>
    </head>
    <body>
      <div class="header">
        <h2>BUKU KAS UMUM (BKU)</h2>
        <p>Periode: ${namaBulanHeader} ${new Date().getFullYear()}</p>
      </div>

      <table>
        <thead>
          <tr>
            <th width="3%">NO</th>
            <th width="12%">TANGGAL</th>
            <th width="15%">NO. BKU</th>
            <th>URAIAN / KETERANGAN</th>
            <th width="15%">KODE BELANJA</th>
            <th width="12%">PENERIMAAN</th>
            <th width="12%">PENGELUARAN</th>
            <th width="14%">SALDO</th>
          </tr>
        </thead>
        <tbody>`;

  let runningSaldo = 0;
  
  if (filteredData.length === 0) {
    html += `<tr><td colspan="8" class="text-center" style="padding:20px;">Tidak ada data transaksi pada periode ini.</td></tr>`;
  } else {
    filteredData.forEach((row, i) => {
      runningSaldo += (row.terima - row.keluar);
      html += `
        <tr>
          <td class="text-center">${i + 1}</td>
          <td class="text-center">${row.tanggalTampil}</td>
          <td class="text-center fw-bold">${row.noBku}</td>
          <td style="text-align: justify;">${row.uraian}</td>
          <td class="text-center">${row.kodeBelanja || '-'}</td>
          <td class="text-end">${row.terima ? 'Rp ' + row.terima.toLocaleString('id-ID') : '-'}</td>
          <td class="text-end">${row.keluar ? 'Rp ' + row.keluar.toLocaleString('id-ID') : '-'}</td>
          <td class="text-end fw-bold">Rp ${runningSaldo.toLocaleString('id-ID')}</td>
        </tr>`;
    });
  }

  html += `
        </tbody>
      </table>

      <div class="footer-container">
        <div class="ttd-box">
          Bandung, ${tglCetakTampil}<br>
          Bendahara Pengeluaran,<br>
          <div class="space-ttd"></div>
          <b style="text-decoration: underline;">( ............................................ )</b><br>
          NIP. ........................................
        </div>
        <div style="clear: both;"></div>
      </div>
    </body>
    </html>`;

  // 4. Konversi HTML ke PDF
  const blob = Utilities.newBlob(html, 'text/html', 'BKU_Report_Temp.html');
  const pdf = blob.getAs('application/pdf').setName('BKU_' + namaBulanHeader + '.pdf');
  
  // 5. Encode ke Base64 untuk dikirim ke Browser
  return "data:application/pdf;base64," + Utilities.base64Encode(pdf.getBytes());
}
